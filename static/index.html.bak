<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Saya's Ontology Adventure</title>
    <style>
        body { 
            font-family: Georgia, serif; 
            background: #0f0a14; 
            color: #e0d0ff; 
            padding: 40px; 
            line-height: 1.7;
        }
        #story { max-width: 720px; margin: 0 auto; }
        .choice { 
            display: block; 
            margin: 12px 0; 
            padding: 12px 18px; 
            background: #1a1428; 
            border-left: 5px solid #ff66cc; 
            cursor: pointer;
        }
        .choice:hover { background: #2a1f3d; }
    </style>
</head>
<body>
    <h2>Saya's Ontology Adventure</h2>
    <div id="story"></div>

    <script>
        let fullStory = `Saya's voice cuts through the darkness like a knife wrapped in velvet and sarcasm.

*Well, well, well...* Look who finally decided to show up. 

I’m Saya. Yeah, *that* Saya. The one who’s going to narrate your little adventure whether you like it or not. 

Don’t get too comfortable, mortal. I bite.`;

        const storyDiv = document.getElementById("story");

        function cleanInk(text) {
            return text
                .replace(/=== \w+ ===/g, '')
                .replace(/[+\*]\s*\[[^\]]+\]\s*->\s*\w+/g, '')
                .replace(/-> \w+/g, '')
                .trim();
        }

        function render(newChunk = "") {
            if (newChunk) {
                const cleaned = cleanInk(newChunk);
                fullStory += "<br><br>" + cleaned;
            }

            storyDiv.innerHTML = `<p>${fullStory}</p>`;

            // Always show these reliable choices
            const choicesDiv = document.createElement("div");
            choicesDiv.innerHTML = `
                <div class="choice" onclick="makeChoice('Tell me more about you, Saya')">Tell me more about you, Saya</div>
                <div class="choice" onclick="makeChoice('Continue the story')">Continue the story</div>
            `;
            storyDiv.appendChild(choicesDiv);
        }
        window.makeChoice = async function(choiceText) {
            const res = await fetch('/choice', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ choice_text: choiceText })
            });

            const data = await res.json();

            if (data.success && data.new_ink) {
                render(data.new_ink);
            } else {
                render("Saya pauses for a moment, thinking...");
            }
        };

        // Initial render
        render();
    </script>
</body>
</html>